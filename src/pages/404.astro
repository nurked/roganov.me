---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Page Not Found | Ivan Roganov" description="This page does not exist." lang="en" canonicalPath="/404/" noindex={true}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-24 sm:py-32 text-center">
    <p class="text-brand-accent font-mono text-sm mb-4">404</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight mb-6">Page not found</h1>
    <p class="text-lg text-gray-400 leading-relaxed mb-10">
      This page doesn't exist — it may have moved when the site was rebuilt.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-6 font-mono text-sm">
      <a href="/" class="text-gray-300 hover:text-brand-accent transition-colors">&larr; Home</a>
      <a href="/blog/" class="text-gray-300 hover:text-brand-accent transition-colors">Blog</a>
    </div>
  </section>
</PageLayout>
