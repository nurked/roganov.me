---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { aggregateTags, tagSlug } from '../../../utils/tagUtils.js';
import { profile } from '../../../config/profile.js';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'en' && !data.draft;
  });
  const byTag = aggregateTags(posts);

  return Array.from(byTag.values()).map((entry) => ({
    params: { tag: entry.slug },
    props: {
      tagSlugValue: entry.slug,
      label: entry.label,
      posts: entry.posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tagSlugValue, label, posts } = Astro.props;

const siteUrl = 'https://roganov.me';
const canonicalPath = `/blog/tags/${tagSlugValue}/`;

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Posts tagged "${label}" — ${profile.name}`,
  description: `All blog posts by ${profile.name} tagged #${label}.`,
  url: `${siteUrl}${canonicalPath}`,
  inLanguage: 'en-US',
  isPartOf: {
    "@type": "Blog",
    name: `${profile.name} — Blog`,
    url: `${siteUrl}/blog/`,
  },
  hasPart: posts.slice(0, 20).map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: `${siteUrl}/blog/${post.data.slug}/`,
    datePublished: post.data.date.toISOString(),
    author: { "@type": "Person", name: profile.name },
  })),
};
---

<PageLayout
  title={`#${label} — Blog | ${profile.name}`}
  description={`Every blog post by ${profile.name} tagged with #${label}. ${posts.length} ${posts.length === 1 ? 'article' : 'articles'}.`}
  lang="en"
  canonicalPath={canonicalPath}
  alternateLangPath={`/ru/blog/tags/${tagSlugValue}/`}
  alternateLang="ru"
  structuredData={collectionLd}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <nav class="mb-10 text-sm" aria-label="Breadcrumb">
      <a href="/blog/" class="text-gray-500 hover:text-brand-accent transition-colors font-mono">&larr; Blog</a>
    </nav>
    <header class="mb-16 pb-10 border-b border-white/10">
      <p class="text-brand-accent text-xs font-mono uppercase tracking-[0.2em] mb-4">Tag</p>
      <h1 class="text-5xl sm:text-6xl font-bold text-white mb-5 tracking-tight">#{label}</h1>
      <p class="text-lg text-gray-400">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with <span class="font-mono text-gray-300">#{label}</span>.
      </p>
    </header>

    <ul class="space-y-0">
      {posts.map((post) => (
        <li>
          <a
            href={`/blog/${post.data.slug}/`}
            class="group grid grid-cols-[88px_1fr] sm:grid-cols-[140px_1fr] gap-5 sm:gap-10 py-6 border-b border-white/5 hover:border-white/20 transition-colors"
          >
            <time
              class="text-sm text-gray-500 font-mono pt-1 tabular-nums"
              datetime={post.data.date.toISOString()}
            >
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit', timeZone: 'UTC' })}
            </time>
            <div>
              <h2 class="text-xl sm:text-2xl font-semibold text-white group-hover:text-brand-accent transition-colors mb-2 tracking-tight">
                {post.data.title}
              </h2>
              <p class="text-gray-400 leading-relaxed mb-3">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {post.data.tags.map((t) => (
                    <span class={`text-xs font-mono ${tagSlug(t) === tagSlugValue ? 'text-brand-accent' : 'text-gray-500'}`}>
                      #{t}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</PageLayout>
