---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils.js';
import { tagSlug } from '../../../utils/tagUtils.js';
import { computeReadingTime } from '../../../utils/readingTime.js';
import { profile } from '../../../config/profile.js';

const lang = 'ru';
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ data }) => {
  return data.lang === 'ru' && !data.draft;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const byYear = new Map();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year).push(post);
}
const years = Array.from(byYear.entries());

// Russian pluralization for "статья / поста / постов"
function ruPlural(n, forms) {
  // forms: [singular, few, many]   e.g. ['статья', 'статьи', 'статей']
  const mod10 = n % 10;
  const mod100 = n % 100;
  if (mod10 === 1 && mod100 !== 11) return forms[0];
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 10 || mod100 >= 20)) return forms[1];
  return forms[2];
}
const postsWord = ruPlural(posts.length, ['статья', 'статьи', 'статей']);

const siteUrl = 'https://roganov.me';
const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: `${profile.name} — Блог`,
  description: "Статьи об инженерии, инструментах, письме и собственных мнениях.",
  url: `${siteUrl}/ru/blog/`,
  inLanguage: 'ru-RU',
  author: {
    "@type": "Person",
    name: profile.name,
    url: siteUrl,
  },
  blogPost: posts.slice(0, 20).map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: `${siteUrl}/ru/blog/${post.data.slug}/`,
    datePublished: post.data.date.toISOString(),
    author: { "@type": "Person", name: profile.name },
    inLanguage: 'ru-RU',
    ...(post.data.tags && post.data.tags.length > 0 ? { keywords: post.data.tags.join(', ') } : {}),
  })),
};
---

<PageLayout
  title={`${t('blog.title')} | Иван Роганов`}
  description="Статьи об инженерии, инструментах, письме и собственных мнениях — Иван Роганов."
  lang={lang}
  canonicalPath="/ru/blog/"
  alternateLangPath="/blog/"
  alternateLang="en"
  structuredData={blogLd}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <header class="mb-20 border-b border-white/10 pb-10">
      <p class="text-brand-accent text-xs font-mono uppercase tracking-[0.2em] mb-4">Писательство</p>
      <h1 class="text-5xl sm:text-6xl font-bold text-white mb-5 tracking-tight">Блог</h1>
      <p class="text-lg text-gray-400 max-w-2xl leading-relaxed">
        Заметки об инженерии, инструментах, письме и иногда — мнения.
        <span class="text-gray-500">{posts.length} {postsWord}, самая ранняя — {posts[posts.length - 1]?.data.date.getFullYear()} год.</span>
      </p>
      <div class="mt-6 flex items-center gap-6">
        <a
          href="/ru/rss.xml"
          class="inline-flex items-center gap-2 text-sm font-mono text-gray-400 hover:text-brand-accent transition-colors"
          aria-label="Подписаться через RSS"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 11a9 9 0 019 9M4 4a16 16 0 0116 16M6 19a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
          Подписаться через RSS
        </a>
        <a
          href="/ru/blog/tags/"
          class="inline-flex items-center gap-2 text-sm font-mono text-gray-400 hover:text-brand-accent transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z" />
          </svg>
          Все теги
        </a>
      </div>
    </header>

    <div class="space-y-20">
      {years.map(([year, yearPosts]) => (
        <section>
          <div class="flex items-baseline gap-4 mb-8">
            <h2 class="text-3xl font-bold text-white/90 tracking-tight">{year}</h2>
            <span class="text-xs text-gray-500 font-mono uppercase tracking-wider">
              {yearPosts.length} {ruPlural(yearPosts.length, ['пост', 'поста', 'постов'])}
            </span>
          </div>
          <ul class="space-y-0">
            {yearPosts.map((post) => (
              <li class="group grid grid-cols-[88px_1fr] sm:grid-cols-[120px_1fr] gap-5 sm:gap-10 py-6 border-b border-white/5 hover:border-white/20 transition-colors">
                <time class="text-sm text-gray-500 font-mono pt-1 tabular-nums" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('ru-RU', { month: 'short', day: '2-digit', timeZone: 'UTC' })}
                </time>
                <div>
                  <h3 class="text-xl sm:text-2xl font-semibold tracking-tight mb-2">
                    <a href={`/ru/blog/${post.data.slug}/`} class="text-white group-hover:text-brand-accent transition-colors">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-gray-400 leading-relaxed mb-3">
                    <a href={`/ru/blog/${post.data.slug}/`} class="text-gray-400 hover:text-gray-200 transition-colors">
                      {post.data.description}
                    </a>
                  </p>
                  <div class="flex flex-wrap gap-x-3 gap-y-1 items-center">
                    <span class="text-xs text-gray-600 font-mono tabular-nums">{computeReadingTime(post.body, 'ru').minutes} мин</span>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <>
                        <span class="text-gray-700" aria-hidden="true">&middot;</span>
                        {post.data.tags.map((tag) => (
                          <a
                            href={`/ru/blog/tags/${tagSlug(tag)}/`}
                            class="text-xs text-gray-500 hover:text-brand-accent font-mono transition-colors"
                          >#{tag}</a>
                        ))}
                      </>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</PageLayout>
