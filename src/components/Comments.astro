---
import { useTranslations } from '../i18n/utils.js';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

// giscus (https://giscus.app) — comments stored as GitHub Discussions on
// nurked/roganov.me, "Announcements" category. Mapped by pathname so EN and
// RU posts get separate threads. Loaded lazily on approach so the script
// never affects page-load performance.
const giscusConfig = {
  'data-repo': 'nurked/roganov.me',
  'data-repo-id': 'R_kgDONt_T-A',
  'data-category': 'Announcements',
  'data-category-id': 'DIC_kwDONt_T-M4C-9Wb',
  'data-mapping': 'pathname',
  'data-strict': '0',
  'data-reactions-enabled': '1',
  'data-emit-metadata': '0',
  'data-input-position': 'top',
  'data-theme': 'transparent_dark',
  'data-lang': lang === 'ru' ? 'ru' : 'en',
};
---

<section class="mt-16 pt-8 border-t border-white/10" aria-label={t('comments.title')}>
  <h2 class="text-xs text-gray-400 font-mono uppercase tracking-[0.2em] mb-6">{t('comments.title')}</h2>
  <div id="giscus-container" data-config={JSON.stringify(giscusConfig)}></div>
</section>

<script is:inline>
  (function () {
    var container = document.getElementById('giscus-container');
    if (!container) return;
    var loaded = false;
    function loadGiscus() {
      if (loaded) return;
      loaded = true;
      var config = JSON.parse(container.getAttribute('data-config'));
      var s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      s.async = true;
      s.crossOrigin = 'anonymous';
      Object.keys(config).forEach(function (k) {
        s.setAttribute(k, config[k]);
      });
      container.appendChild(s);
    }
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        if (entries.some(function (e) { return e.isIntersecting; })) {
          loadGiscus();
          observer.disconnect();
        }
      }, { rootMargin: '600px' });
      observer.observe(container);
    } else {
      loadGiscus();
    }
  })();
</script>
