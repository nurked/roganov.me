---
import '../styles/global.css';
import { profile } from '../config/profile.js';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  canonicalPath?: string;
  alternateLangPath?: string;
  alternateLang?: string;
  ogType?: 'website' | 'article' | 'profile';
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
    section?: string;
  };
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = profile.meta.title,
  description = profile.meta.description,
  image = '/ivan.png',
  lang = 'en',
  canonicalPath = '',
  alternateLangPath,
  alternateLang,
  ogType = 'website',
  article,
  structuredData,
} = Astro.props;

const siteUrl = 'https://roganov.me';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const imageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Locale codes for og:locale
const ogLocale = lang === 'ru' ? 'ru_RU' : 'en_US';
const ogLocaleAlt = alternateLang === 'ru' ? 'ru_RU' : alternateLang === 'en' ? 'en_US' : null;

// Default Person JSON-LD for the site
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  alternateName: profile.aliases,
  url: siteUrl,
  image: imageUrl,
  sameAs: [
    profile.social.linkedin,
    profile.social.medium,
    profile.social.telegram,
    profile.social.github,
  ],
  jobTitle: profile.position,
  worksFor: {
    "@type": "Organization",
    name: profile.company,
    alternateName: "IFCLLC",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Clearwater",
    addressRegion: "FL",
    addressCountry: "US",
  },
  email: profile.contact.email,
  telephone: profile.contact.phone,
  knowsAbout: profile.expertise,
};

const extraLd = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={profile.meta.keywords.join(', ')} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={`${profile.name} — ${profile.position}`} />
    <meta property="og:site_name" content={profile.company} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlt && <meta property="og:locale:alternate" content={ogLocaleAlt} />}

    {ogType === 'article' && article?.publishedTime && (
      <meta property="article:published_time" content={article.publishedTime} />
    )}
    {ogType === 'article' && article?.modifiedTime && (
      <meta property="article:modified_time" content={article.modifiedTime} />
    )}
    {ogType === 'article' && (article?.author || profile.name) && (
      <meta property="article:author" content={article?.author || profile.name} />
    )}
    {ogType === 'article' && article?.section && (
      <meta property="article:section" content={article.section} />
    )}
    {ogType === 'article' && article?.tags && article.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- hreflang for i18n -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternateLangPath && alternateLang && (
      <link rel="alternate" hreflang={alternateLang} href={`${siteUrl}${alternateLangPath}`} />
    )}
    {/* x-default always points at EN (the site's default locale) */}
    {lang === 'en' && (
      <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    )}
    {lang !== 'en' && alternateLangPath && alternateLang === 'en' && (
      <link rel="alternate" hreflang="x-default" href={`${siteUrl}${alternateLangPath}`} />
    )}

    <!-- Structured Data: Person (site-wide) -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />

    <!-- Page-specific Structured Data -->
    {extraLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3WR8FYRV2N"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3WR8FYRV2N');
    </script>

    <!-- Hash route redirect for backwards compatibility -->
    <script is:inline>
      if (window.location.hash && window.location.hash.startsWith('#/')) {
        var newPath = window.location.hash.slice(1);
        window.location.replace(newPath);
      }
    </script>
  </head>
  <body class="bg-surface-base text-gray-300 font-inter">
    <slot />

    <!-- Intersection Observer for scroll animations -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-in-section').forEach(function(el) {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
